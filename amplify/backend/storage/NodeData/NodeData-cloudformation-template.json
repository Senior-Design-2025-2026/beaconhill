{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "NodeData DynamoDB table — stores sensor node configuration data.",
  "Parameters": {
    "env": {
      "Type": "String",
      "Default": "dev"
    },
    "tableName": {
      "Type": "String",
      "Default": "NodeData"
    }
  },
  "Resources": {
    "NodeDataTable": {
      "Type": "AWS::DynamoDB::Table",
      "Properties": {
        "TableName": { "Ref": "tableName" },
        "AttributeDefinitions": [
          { "AttributeName": "nodeId", "AttributeType": "S" }
        ],
        "KeySchema": [
          { "AttributeName": "nodeId", "KeyType": "HASH" }
        ],
        "BillingMode": "PAY_PER_REQUEST"
      }
    }
  },
  "Outputs": {
    "Name": {
      "Value": { "Ref": "NodeDataTable" }
    },
    "Arn": {
      "Value": { "Fn::GetAtt": ["NodeDataTable", "Arn"] }
    }
  }
}
